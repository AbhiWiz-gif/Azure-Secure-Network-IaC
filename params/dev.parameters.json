{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "localVnetName": {"value": "vnet-dev-aueast"},
    "remoteVnetName": { "value": "vnet-test-aueast"},
    "linuxWebConfig": {
      "value": {
        "baseName": "test-app",
        "vmSize": "Standard_E2s_v3",
        "count": 1,
        "adminUsername": "linuxadmin"
      }},
    "lbName": {"value": "ilb-dev-aueast-01"},
    "bastion": {
      "value": {
        "pipName": "pip-bas-dev-aueast-01",
        "name": "bas-dev-aueast-01"
      }
    },
    "winWebAdminPassword": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/115fcb0f-8cae-4e50-a28d-0e0e871053df/resourceGroups/app-grp/providers/Microsoft.KeyVault/vaults/keyvault0099"
        },
        "secretName": "win-web-admin-password"
      }
    },
    "linuxWebAdminPassword": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/115fcb0f-8cae-4e50-a28d-0e0e871053df/resourceGroups/app-grp/providers/Microsoft.KeyVault/vaults/keyvault0099"
        },
        "secretName": "linux-web-admin-password"
      }
    },
    "winWebConfig": {
      "value": {
          "scriptUri": "https://stlearningdevaueast09.blob.core.windows.net/scripts/setup-iis.ps1?sp=r&st=2026-04-20T09:29:11Z&se=2026-04-20T17:44:11Z&spr=https&sv=2025-11-05&sr=b&sig=eP57m%2BBsYHau5KBaW2RbsrabnqmqF1RxTsY1jbYvjaE%3D",
          "vmSize": "Standard_E2s_v3",
          "adminUserName": "azureadmin",
          "baseName": "dev-web",
          "count": 2
        }
    },
    "location": {"value": "australiaeast"},
    "storageAccountName": {"value": "stlearningdevaueast09"},
    "vnet": {
      "value": {
        "name": "vnet-dev-aueast",
        "addressPrefixes": ["10.0.0.0/16"],
        "subnets": [
          {"name": "snet-dev-aueast-web-01", "prefix": "10.0.0.0/24"},
          {"name": "snet-dev-aueast-db-01", "prefix": "10.0.1.0/24"},
          {"name": "AzureBastionSubnet", "prefix": "10.0.2.0/24"}
        ]
      }
    },
    "testvnet":{
      "value": {
        "name": "vnet-test-aueast",
        "addressPrefixes": ["10.1.0.0/16"],
        "subnets": [
          {
            "name": "snet-test-aueast-app", "prefix": "10.1.0.0/24"
          }
        ]
      }
    },
    "nsg": {
      "value": {
        "name": "nsg-az104-shared-aueast-01",
        "rules": [
          {
            "name": "in-allow-rdp-admin",
            "properties": {
              "description": "Allow RDP for admin access.",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "3389",
              "sourceAddressPrefix": "*",
              "destinationAddressPrefix": "*",
              "access": "Allow",
              "priority": 400,
              "direction": "Inbound"
            }
          },
          {
            "name": "in-allow-http-from-internet-to-10-0-0-4",
            "properties": {
              "description": "Allow HTTP from the Internet service tag to 10.0.0.4",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "80",
              "sourceAddressPrefix": "Internet",
              "destinationAddressPrefix": "10.0.0.4",
              "access": "Allow",
              "priority": 410,
              "direction": "Inbound"
            }
          }
        ]
      }
    }
  }
}